generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  statusChanges OrderStatusHistory[]
}

model Customer {
  id         String   @id @default(uuid())
  fullName   String
  cpf        String   @unique
  email      String
  phone      String
  zipCode    String
  street     String
  number     String
  complement String   @default("")
  district   String
  city       String
  state      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders Order[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Coupon {
  id         String    @id @default(uuid())
  code       String    @unique
  type       String // "percentage" or "fixed"
  value      Float
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  usageLimit Int?
  usageCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Order {
  id                    String    @id @default(uuid())
  orderNumber           String    @unique
  customerId            String
  customer              Customer  @relation(fields: [customerId], references: [id])
  subtotal              Float
  shippingType          String
  shippingRegion        String
  shippingValue         Float
  discountValue         Float     @default(0)
  couponCode            String?
  totalValue            Float
  status                String    @default("Aguardando pagamento")
  paymentProofPath      String?
  paymentReportedAt     DateTime?
  customerCpfSnapshot   String
  customerNameSnapshot  String
  customerEmailSnapshot String
  customerPhoneSnapshot String
  shippingZipCode       String
  shippingStreet        String
  shippingNumber        String
  shippingComplement    String    @default("")
  shippingDistrict      String
  shippingCity          String
  shippingState         String
  internalNotes         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
}

model OrderItem {
  id                  String  @id @default(uuid())
  orderId             String
  order               Order   @relation(fields: [orderId], references: [id])
  productId           String
  product             Product @relation(fields: [productId], references: [id])
  productNameSnapshot String
  unitPrice           Float
  quantity            Int
  lineTotal           Float
}

model OrderStatusHistory {
  id               String     @id @default(uuid())
  orderId          String
  order            Order      @relation(fields: [orderId], references: [id])
  previousStatus   String
  newStatus        String
  changedAt        DateTime   @default(now())
  changedByAdminId String?
  changedByAdmin   AdminUser? @relation(fields: [changedByAdminId], references: [id])
  comment          String?
}
